{
  "name": "flow-language",
  "displayName": "Flow Programming Language",
  "description": "Syntax highlighting and language support for the Flow programming language",
  "version": "1.0.0",
  "publisher": "flow-lang",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:flow",
    "onCommand:flow.runFile",
    "onCommand:flow.compileFile",
    "onCommand:flow.debugFile"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "flow",
        "aliases": [
          "Flow",
          "flow"
        ],
        "extensions": [
          ".fl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flow",
        "scopeName": "source.flow",
        "path": "./syntaxes/flow.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "flow",
        "path": "./snippets/flow.json"
      }
    ],
    "commands": [
      {
        "command": "flow.runFile",
        "title": "Flow: Run File"
      },
      {
        "command": "flow.compileFile",
        "title": "Flow: Compile File"
      },
      {
        "command": "flow.debugFile",
        "title": "Flow: Debug File"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Flow",
      "properties": {
        "flow.compilerPath": {
          "type": "string",
          "default": "flow.exe",
          "description": "Path to the Flow executable or interpreter used by Flow commands"
        }
      }
    }
  },
  "dependencies": {
    "vsce": "^2.15.0"
  }
}
